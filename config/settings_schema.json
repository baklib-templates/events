[
  {
    "name": "theme_info",
    "theme_name": "events",
    "theme_label": "Events",
    "theme_description": "B2B Webinar & Event Hub —— 活动预告与长尾资源沉淀站点主题。",
    "theme_version": "0.2.1",
    "theme_syntax_version": "v2",
    "theme_scope": "cms",
    "theme_author": "Baklib",
    "theme_documentation_url": "https://help.baklib.cn/",
    "theme_support_url": "https://help.baklib.cn/",
    "theme_thumb_url": "images/theme/thumb.png",
    "theme_preview_images": [
      "images/theme/preview-index.png",
      "images/theme/preview-page.png"
    ],
    "theme_languages": [
      { "name": "中文简体", "value": "zh-CN" },
      { "name": "English", "value": "en" }
    ],
    "recommendations": {
      "color_schemas": {
        "default": {
          "name": "Teal / B2B",
          "colors": {
            "--theme-color-base-100": "#ffffff",
            "--theme-color-base-200": "#f8fafc",
            "--theme-color-base-300": "#e2e8f0",
            "--theme-color-base-content": "#0f172a",
            "--theme-color-primary": "#0d9488",
            "--theme-color-primary-content": "#ffffff",
            "--theme-color-secondary": "#1f2937",
            "--theme-color-secondary-content": "#ffffff",
            "--theme-color-accent": "#2dd4bf",
            "--theme-color-accent-content": "#ffffff",
            "--theme-color-neutral": "#1f2937",
            "--theme-color-neutral-content": "#ffffff",
            "--theme-color-info": "#0ea5e9",
            "--theme-color-info-content": "#ffffff",
            "--theme-color-success": "#22c55e",
            "--theme-color-success-content": "#ffffff",
            "--theme-color-warning": "#f59e0b",
            "--theme-color-warning-content": "#0f172a",
            "--theme-color-error": "#ef4444",
            "--theme-color-error-content": "#ffffff"
          }
        },
        "midnight": {
          "name": "Midnight",
          "colors": {
            "--theme-color-base-100": "#0f172a",
            "--theme-color-base-200": "#0b1220",
            "--theme-color-base-300": "#1e293b",
            "--theme-color-base-content": "#f8fafc",
            "--theme-color-primary": "#2dd4bf",
            "--theme-color-primary-content": "#0f172a",
            "--theme-color-secondary": "#f8fafc",
            "--theme-color-secondary-content": "#0f172a",
            "--theme-color-accent": "#5eead4",
            "--theme-color-accent-content": "#0f172a",
            "--theme-color-neutral": "#f8fafc",
            "--theme-color-neutral-content": "#0f172a",
            "--theme-color-info": "#38bdf8",
            "--theme-color-info-content": "#0f172a",
            "--theme-color-success": "#4ade80",
            "--theme-color-success-content": "#0f172a",
            "--theme-color-warning": "#fbbf24",
            "--theme-color-warning-content": "#0f172a",
            "--theme-color-error": "#f87171",
            "--theme-color-error-content": "#0f172a"
          }
        }
      }
    }
  },
  {
    "name": "站点设置",
    "settings": [
      {
        "id": "brand_name",
        "type": "text",
        "label": "品牌名称",
        "default": "Baklib Events"
      },
      {
        "id": "brand_slogan",
        "type": "textarea",
        "label": "品牌简介（页脚展示）",
        "default": "The B2B knowledge hub for product, marketing, and growth professionals — every webinar, every replay, every resource in one place.",
        "rows": 3
      },
      {
        "id": "cta_label",
        "type": "text",
        "label": "顶栏 CTA 文案",
        "default": "Browse Webinars"
      },
      {
        "id": "cta_url",
        "type": "text",
        "label": "顶栏 CTA 链接",
        "info": "可选。可指向某场活动详情或其它外链；留空则不显示顶栏次要按钮。",
        "default": ""
      },
      {
        "id": "hero_title",
        "type": "text",
        "label": "Hero 标题",
        "info": "留空则使用品牌名称（站点设置「品牌名称」或站点名）。",
        "default": ""
      },
      {
        "id": "hero_description",
        "type": "textarea",
        "label": "Hero 描述",
        "rows": 3,
        "default": ""
      },
      {
        "id": "hero_url",
        "type": "text",
        "label": "Hero 主按钮链接",
        "info": "可填站内路径或外链。留空则不显示主按钮。",
        "default": ""
      },
      {
        "id": "hero_cover_image",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 1600,
        "label": "Hero 背景图",
        "default": ""
      },
      {
        "id": "press_logos_html",
        "type": "html",
        "label": "首页 Logo 墙 HTML（可选，<img> 列表）",
        "rows": 4
      },
      {
        "id": "company_address",
        "type": "textarea",
        "label": "公司地址（页脚展示）",
        "rows": 2,
        "default": ""
      },
      {
        "id": "contact_email",
        "type": "text",
        "label": "联系邮箱（页脚展示）",
        "default": ""
      }
    ]
  },
  {
    "name": "t:schema.custom_html.name",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.head_html.label",
        "info": "t:schema.custom_html.settings.head_html.info",
        "rows": 10,
        "placeholder": "t:schema.custom_html.settings.head_html.placeholder"
      },
      {
        "id": "header_menu_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.header_menu_html.label",
        "info": "t:schema.custom_html.settings.header_menu_html.info",
        "rows": 6,
        "placeholder": "t:schema.custom_html.settings.header_menu_html.placeholder"
      },
      {
        "id": "footer_menu_html",
        "type": "html",
        "label": "t:schema.custom_html.settings.footer_menu_html.label",
        "info": "t:schema.custom_html.settings.footer_menu_html.info",
        "rows": 6,
        "placeholder": "t:schema.custom_html.settings.footer_menu_html.placeholder"
      }
    ]
  }
]
