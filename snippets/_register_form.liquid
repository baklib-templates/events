{%- comment -%}
  Inline registration form using site-builtin form_tag 'feedback'.
  Inputs:
    event: PageDrop (template_name == 'event'), used to bind feedback page context.
{%- endcomment -%}

<div id="register-form-{{ event.id }}" class="rounded-2xl border border-base-300/50 bg-base-100 p-6 shadow-sm sm:p-8">
  <div class="mb-5">
    <h3 class="text-lg font-semibold tracking-tight text-base-content">Reserve your seat</h3>
    <p class="mt-1 text-sm text-base-content/70">We will email you the join link a day before the webinar.</p>
  </div>

  {% form_tag 'feedback', event %}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="sm:col-span-1">
        <label class="block text-xs font-semibold text-base-content" for="reg-name-{{ event.id }}">Full name *</label>
        <input
          id="reg-name-{{ event.id }}"
          type="text"
          name="feedback[name]"
          required
          autocomplete="name"
          class="form-input mt-1"
          placeholder="Jane Doe"
        />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-xs font-semibold text-base-content" for="reg-email-{{ event.id }}">Work email *</label>
        <input
          id="reg-email-{{ event.id }}"
          type="email"
          name="feedback[email]"
          required
          autocomplete="email"
          class="form-input mt-1"
          placeholder="jane@company.com"
        />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-xs font-semibold text-base-content" for="reg-company-{{ event.id }}">Company</label>
        <input
          id="reg-company-{{ event.id }}"
          type="text"
          name="feedback[company]"
          autocomplete="organization"
          class="form-input mt-1"
          placeholder="Acme Inc."
        />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-xs font-semibold text-base-content" for="reg-job-{{ event.id }}">Job title</label>
        <input
          id="reg-job-{{ event.id }}"
          type="text"
          name="feedback[job_title]"
          autocomplete="organization-title"
          class="form-input mt-1"
          placeholder="Head of Marketing"
        />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs font-semibold text-base-content" for="reg-phone-{{ event.id }}">Phone (optional)</label>
        <input
          id="reg-phone-{{ event.id }}"
          type="tel"
          name="feedback[phone]"
          autocomplete="tel"
          class="form-input mt-1"
          placeholder="+1 555 0100"
        />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs font-semibold text-base-content" for="reg-question-{{ event.id }}">Anything you'd like the speakers to address?</label>
        <textarea
          id="reg-question-{{ event.id }}"
          name="feedback[message]"
          rows="3"
          class="form-input mt-1"
          placeholder="Optional"
        ></textarea>
      </div>
      <div class="sm:col-span-2 flex items-start gap-2">
        <input id="reg-consent-{{ event.id }}" type="checkbox" name="feedback[consent]" value="1" required class="mt-1 h-4 w-4 rounded border-base-300 text-primary focus:ring-primary" />
        <label for="reg-consent-{{ event.id }}" class="text-xs leading-5 text-base-content/70">
          I agree to receive event communications and accept the <a href="#" class="text-primary hover:underline">privacy policy</a>.
        </label>
      </div>
    </div>

    <div class="mt-6 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-between">
      <button type="submit" class="btn btn-primary btn-lg sm:flex-1" data-disable-with="Submitting…">
        Save my seat
      </button>
      <p class="text-xs text-base-content/50 sm:max-w-xs sm:text-right">
        We will never share your information. Unsubscribe any time.
      </p>
    </div>
  {% endform_tag %}
</div>
