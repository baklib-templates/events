{%- assign brand_name = site.settings.brand_name | default: site.name -%}
{%- assign brand_slogan = site.settings.brand_slogan | presence -%}
{%- assign company_address = site.settings.company_address | presence -%}
{%- assign contact_email = site.settings.contact_email | presence -%}
{%- assign footer_html = site.settings.footer_menu_html | presence -%}
{%- assign root = site.pages['/'] -%}

<footer class="mt-auto border-t border-base-300/40 bg-base-200 text-sm text-base-content/70">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-4">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2">
          {%- assign favicon_url = site.favicon_url | presence -%}
          {%- if favicon_url -%}
            <img class="h-8 w-8 rounded-md object-cover" src="{{ favicon_url }}" alt="" />
          {%- else -%}
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary text-sm font-bold text-primary-content">
              {{ brand_name | slice: 0 | upcase }}
            </span>
          {%- endif -%}
          <span class="text-base font-semibold text-base-content">{{ brand_name }}</span>
        </div>
        {%- if brand_slogan -%}
          <p class="mt-4 max-w-md leading-6">{{ brand_slogan }}</p>
        {%- endif -%}
        {%- if contact_email -%}
          <p class="mt-4">
            <a class="font-medium text-base-content hover:text-primary" href="mailto:{{ contact_email }}">{{ contact_email }}</a>
          </p>
        {%- endif -%}
        {%- if company_address -%}
          <p class="mt-2 leading-6">{{ company_address }}</p>
        {%- endif -%}
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content">Explore</h3>
        <ul class="mt-4 space-y-3">
          {%- if root -%}
            {%- for item in root.children_in_list -%}
              {%- if forloop.index0 < 6 -%}
                <li>
                  <a
                    href="{{ item.path }}"
                    class="hover:text-primary"
                    data-turbo-frame="main-content-frame"
                    data-turbo-action="advance"
                  >{{ item.link_text | default: item.name }}</a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content">Resources</h3>
        <ul class="mt-4 space-y-3">
          {%- if site.search_path -%}
            <li><a class="hover:text-primary" href="{{ site.search_path }}" data-turbo-frame="main-content-frame" data-turbo-action="advance">Search</a></li>
          {%- endif -%}
          {%- if footer_html -%}
            {{ footer_html }}
          {%- endif -%}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-base-300/40 pt-6 sm:flex-row sm:items-center">
      <div class="text-xs text-base-content/60">
        © {{ 'now' | date: '%Y' }} {{ brand_name }}. All rights reserved.
      </div>
      <div class="flex flex-wrap items-center gap-4 text-xs text-base-content/60">
        <a class="hover:text-primary" href="#">Terms</a>
        <a class="hover:text-primary" href="#">Privacy</a>
      </div>
    </div>
  </div>
</footer>
