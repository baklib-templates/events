{%- assign brand_name = site.name -%}
{%- assign footer_html = site.settings.footer_html | presence -%}
{%- assign root = site.pages['/'] -%}
{%- assign root_id = nil -%}
{%- if root -%}
  {%- assign root_id = root.id -%}
{%- endif -%}
{% query footer_nav_q from site.pages %}
{
  "where": {
    "template_name_eq": "channel"
  },
  "order_by": ["published_at"],
  "limit": 60
}
{% endquery %}

<footer class="mt-auto border-t border-base-300/50 bg-base-200/60">
  <div class="page-container py-10">
    <div class="grid gap-10 lg:grid-cols-3">
      <div>
        <div class="flex items-center gap-3">
          {%- assign logo_url = site.settings.logo_url | presence -%}
          {%- assign favicon_url = site.favicon_url | presence -%}
          {%- if logo_url -%}
            <img class="h-8 w-auto max-w-36 object-contain" src="{{ logo_url }}" alt="{{ brand_name | escape_once }}" loading="lazy" />
          {%- elsif favicon_url -%}
            <img class="h-8 w-8 rounded-md object-cover" src="{{ favicon_url }}" alt="" loading="lazy" />
          {%- else -%}
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary text-sm font-bold text-primary-content">{{ brand_name | slice: 0 | upcase }}</span>
          {%- endif -%}
          <span class="font-semibold text-base-content">{{ brand_name }}</span>
        </div>
        <p class="mt-3 text-sm text-base-content/70">Event hub for conferences, webinars, training programs, and meetup resources.</p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Explore</h3>
        <ul class="mt-4 space-y-3">
          {%- for item in footer_nav_q -%}
            {%- if item.parent_id == root_id -%}
              <li>
                <a
                  href="{{ item.path | default: item.url }}"
                  class="text-sm text-base-content/80 hover:text-primary"
                  data-turbo-frame="main-content-frame"
                  data-turbo-action="advance"
                >{% render 'page_title', item: item %}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Resources</h3>
        <ul class="mt-4 space-y-3">
          {%- if site.search_path -%}
            <li><a class="text-sm text-base-content/80 hover:text-primary" href="{{ site.search_path }}" data-turbo-frame="main-content-frame" data-turbo-action="advance">Search</a></li>
          {%- endif -%}
          {%- if footer_html -%}
            <li class="text-sm text-base-content/80">{{ footer_html }}</li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-base-300/50 pt-5 text-xs text-base-content/60">© {{ 'now' | date: '%Y' }} {{ brand_name }}. All rights reserved.</div>
  </div>
</footer>
