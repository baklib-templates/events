{%- comment -%}
  Generic sidebar for the Events IA.
  Inputs (optional):
    current_page: current page drop
    tags: array of tags
    sync_filter: boolean for Alpine filter mode
{%- endcomment -%}

{%- assign root = site.pages['/'] -%}
{%- assign root_id = nil -%}
{%- if root -%}{%- assign root_id = root.id -%}{%- endif -%}

{% query sb_channels from site.pages %}
{
  "where": {
    "template_name_eq": "channel"
  },
  "order_by": ["published_at"],
  "limit": 80
}
{% endquery %}

{% query sb_articles from site.pages %}
{
  "where": {
    "template_name_eq": "page"
  },
  "order_by": ["-published_at"],
  "limit": 80
}
{% endquery %}

<aside class="space-y-8">
  <div>
    <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Events</h3>
    <ul class="mt-3 space-y-1 text-sm">
      {%- for ch in sb_channels -%}
        {%- if ch.parent_id == root_id -%}
          {%- assign is_current = false -%}
          {%- if current_page and ch.id == current_page.id -%}{%- assign is_current = true -%}{%- endif -%}
          <li>
            <a
              href="{{ ch.path | default: ch.url }}"
              class="flex items-center justify-between rounded-md px-3 py-2 transition {% if is_current %}bg-primary/10 text-primary font-semibold{% else %}text-base-content/80 hover:bg-base-200 hover:text-base-content{% endif %}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              {% if is_current %}aria-current="page"{% endif %}
            >
              <span>{% render 'page_title', item: ch %}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>

  {%- assign tags_size = tags | size -%}
  {%- if tags_size > 0 -%}
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Tags</h3>
      <div class="mt-3 flex flex-wrap gap-2">
        {%- if sync_filter -%}
          <button
            type="button"
            class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium transition"
            :class="tag === '' ? 'border-primary bg-primary text-primary-content' : 'border-base-300/50 text-base-content/80 hover:border-primary/50'"
            @click="tag = ''"
          >All</button>
        {%- endif -%}
        {%- for t in tags -%}
          {%- if sync_filter -%}
            <button
              type="button"
              class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium transition"
              :class="tag === '{{ t.slug }}' ? 'border-primary bg-primary text-primary-content' : 'border-base-300/50 text-base-content/80 hover:border-primary/50'"
              @click="tag = '{{ t.slug }}'"
            >{{ t.name }}</button>
          {%- else -%}
            <a
              href="{{ t.path | default: t.url }}"
              class="inline-flex items-center rounded-full border border-base-300/50 px-3 py-1 text-xs font-medium text-base-content/80 transition hover:border-primary/50 hover:text-primary"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >{{ t.name }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div>
    <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Latest articles</h3>
    <ul class="mt-3 space-y-3">
      {%- for art in sb_articles limit: 5 -%}
        <li>
          <a
            href="{{ art.path | default: art.url }}"
            class="group block"
            data-turbo-frame="main-content-frame"
            data-turbo-action="advance"
          >
            <div class="line-clamp-2 text-sm font-semibold leading-snug text-base-content group-hover:text-primary">{% render 'page_title', item: art %}</div>
            <div class="mt-1 text-xs text-base-content/60">{{ art.published_at | default: art.created_at | date: '%b %d, %Y' }}</div>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</aside>
