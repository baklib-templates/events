{%- comment -%}
  Speaker card for team grid.
  Inputs:
    speaker: PageDrop (template_name == 'team_member')
{%- endcomment -%}

{%- assign job_title = speaker.settings.job_title | presence -%}
{%- assign company = speaker.settings.company | presence -%}

<a
  href="{{ speaker.path | default: speaker.url }}"
  data-turbo-frame="main-content-frame"
  data-turbo-action="advance"
  class="group flex flex-col items-center rounded-xl border border-base-300/40 bg-base-100 p-6 text-center transition hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md"
>
  {% render 'speaker_avatar', speaker: speaker, size: 'lg' %}
  <h3 class="mt-4 text-base font-semibold tracking-tight text-base-content group-hover:text-primary">
    {% render 'page_title', item: speaker %}
  </h3>
  {%- if job_title -%}
    <p class="mt-1 text-xs font-medium text-base-content/70">
      {{ job_title }}{% if company %}<span class="text-base-content/40"> · </span>{{ company }}{% endif %}
    </p>
  {%- elsif company -%}
    <p class="mt-1 text-xs font-medium text-base-content/70">{{ company }}</p>
  {%- endif -%}
</a>
