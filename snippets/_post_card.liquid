{%- comment -%}
  Post / news card.
  Inputs:
    post: PageDrop (template_name == 'page')
    variant: 'default' | 'compact' | 'horizontal'
{%- endcomment -%}

{%- assign cover = post.settings.thumb_image | default: post.settings.thumb_image_url | presence -%}
{%- assign published = post.published_at | default: post.created_at -%}

{%- if variant == 'horizontal' -%}
  <a
    href="{{ post.path | default: post.url }}"
    data-turbo-frame="main-content-frame"
    data-turbo-action="advance"
    class="group flex gap-4 rounded-lg p-2 transition hover:bg-base-200/60"
  >
    <div class="relative aspect-video w-28 shrink-0 overflow-hidden rounded-md bg-base-200">
      {%- if cover -%}
        <img src="{{ cover }}" alt="" class="h-full w-full object-cover" loading="lazy" />
      {%- endif -%}
    </div>
    <div class="min-w-0">
      <div class="text-xs text-base-content/60">{{ published | date: '%b %d, %Y' }}</div>
      <h4 class="mt-1 line-clamp-2 text-sm font-semibold leading-snug text-base-content group-hover:text-primary">
        {% render 'page_title', item: post %}
      </h4>
    </div>
  </a>
{%- else -%}
  <a
    href="{{ post.path | default: post.url }}"
    data-turbo-frame="main-content-frame"
    data-turbo-action="advance"
    class="group flex h-full flex-col overflow-hidden rounded-box border border-base-300/50 bg-base-100 transition hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md"
  >
    <div class="relative aspect-[16/9] w-full overflow-hidden bg-base-200">
      {%- if cover -%}
        <img src="{{ cover }}" alt="" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]" loading="lazy" />
      {%- else -%}
        <div class="flex h-full w-full items-center justify-center text-base-content/30">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="h-12 w-12"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/></svg>
        </div>
      {%- endif -%}
    </div>
    <div class="flex flex-1 flex-col p-5">
      <div class="flex items-center gap-2 text-xs font-medium text-base-content/60">
        <time datetime="{{ published | date: '%Y-%m-%d' }}">{{ published | date: '%b %d, %Y' }}</time>
        {%- if post.parent -%}
          <span aria-hidden="true">·</span>
          <span>{% render 'page_title', item: post.parent %}</span>
        {%- endif -%}
      </div>
      <h3 class="mt-2 line-clamp-2 text-base font-semibold leading-snug tracking-tight text-base-content group-hover:text-primary">
        {% render 'page_title', item: post %}
      </h3>
      {%- if post.settings.description != blank -%}
        <p class="mt-2 line-clamp-2 text-sm text-base-content/70">{{ post.settings.description }}</p>
      {%- endif -%}
    </div>
  </a>
{%- endif -%}
