{%- comment -%}
  Add to Calendar dropdown (Google Calendar link + .ics download via controller).
  Inputs:
    event: PageDrop
{%- endcomment -%}

{%- assign start_iso = event.settings.start_datetime -%}
{%- assign end_iso = event.settings.end_datetime -%}
{%- assign start_ts = start_iso | date: '%s' | plus: 0 -%}
{%- assign end_ts = end_iso | date: '%s' | plus: 0 -%}
{%- if end_ts == 0 and start_ts > 0 -%}
  {%- assign end_ts = start_ts | plus: 3600 -%}
  {%- assign end_iso = end_ts | date: '%Y-%m-%dT%H:%M:%S' -%}
{%- endif -%}

{%- assign cal_start = start_iso | date: '%Y%m%dT%H%M%S' -%}
{%- assign cal_end = end_iso | date: '%Y%m%dT%H%M%S' -%}
{%- assign ev_title = event.link_text | default: event.name -%}
{%- assign ev_desc = event.settings.description | default: '' -%}
{%- assign ev_loc = event.settings.location | default: 'Online' -%}
{%- assign ev_url = site.host | append: event.path -%}

{%- capture gcal_url -%}
https://www.google.com/calendar/render?action=TEMPLATE&text={{ ev_title | url_encode }}&dates={{ cal_start }}Z/{{ cal_end }}Z&details={{ ev_desc | strip_html | url_encode }}&location={{ ev_loc | url_encode }}&sprop=website:{{ ev_url | url_encode }}
{%- endcapture -%}

<div
  class="relative inline-block text-left"
  x-data="{ open: false }"
  data-controller="add-to-calendar"
  data-add-to-calendar-title-value="{{ ev_title | escape }}"
  data-add-to-calendar-description-value="{{ ev_desc | strip_html | escape }}"
  data-add-to-calendar-location-value="{{ ev_loc | escape }}"
  data-add-to-calendar-start-value="{{ start_iso }}"
  data-add-to-calendar-end-value="{{ end_iso }}"
  data-add-to-calendar-url-value="{{ ev_url }}"
>
  <button
    type="button"
    class="btn btn-outline"
    @click="open = !open"
    :aria-expanded="open"
    aria-haspopup="menu"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg>
    Add to Calendar
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
  </button>
  <div
    class="absolute right-0 z-20 mt-2 w-56 origin-top-right rounded-lg border border-base-300/40 bg-base-100 py-1 shadow-lg ring-1 ring-black/5"
    x-show="open"
    x-cloak
    x-transition.opacity
    @click.outside="open = false"
    style="display:none;"
    role="menu"
  >
    <a
      href="{{ gcal_url | strip_newlines }}"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-2 px-3 py-2 text-sm text-base-content hover:bg-base-200"
    >
      <span>Google Calendar</span>
    </a>
    <button
      type="button"
      class="flex w-full items-center gap-2 px-3 py-2 text-left text-sm text-base-content hover:bg-base-200"
      data-action="add-to-calendar#download"
    >
      Apple / Outlook (.ics)
    </button>
  </div>
</div>
