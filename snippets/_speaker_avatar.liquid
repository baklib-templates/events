{%- comment -%}
  Inputs:
    speaker: PageDrop (template_name == 'team_member')
    size: 'sm' (default) | 'md' | 'lg' | 'xl'
{%- endcomment -%}

{%- assign avatar = speaker.settings.avatar | presence -%}
{%- assign size_cls = 'h-10 w-10 text-sm' -%}
{%- if size == 'md' -%}
  {%- assign size_cls = 'h-14 w-14 text-base' -%}
{%- elsif size == 'lg' -%}
  {%- assign size_cls = 'h-20 w-20 text-lg' -%}
{%- elsif size == 'xl' -%}
  {%- assign size_cls = 'h-28 w-28 text-xl' -%}
{%- endif -%}

{%- capture _spk_nm %}{% render 'page_title', item: speaker %}{% endcapture -%}
{%- assign initial = _spk_nm | strip | slice: 0 | upcase -%}

<span class="inline-flex {{ size_cls }} shrink-0 items-center justify-center overflow-hidden rounded-full bg-base-200 font-semibold text-base-content/70 ring-1 ring-base-300/50">
  {%- if avatar -%}
    <img src="{{ avatar }}" alt="{{ _spk_nm | strip | escape }}" class="h-full w-full object-cover" loading="lazy" />
  {%- else -%}
    {{ initial }}
  {%- endif -%}
</span>
