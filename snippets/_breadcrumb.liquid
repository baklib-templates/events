{% comment %} 
  面包屑导航
  变量:
  - breadcrumb: 面包屑导航数据
  - current: 当前页面
{% endcomment %}

<div class="breadcrumbs text-sm flex justify-end">
  <ul>
    {% for item in breadcrumb %}
      <li class="{% if forloop.last %}text-primary{% else %}text-base-content/60{% endif %}">
        {% assign _bc_href = item.path | default: item.url %}
        {% if _bc_href %}
          <a href="{{ _bc_href }}">{% render 'page_title', item: item %}</a>
        {% else %}
          {% render 'page_title', item: item %}
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</div>