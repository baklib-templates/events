{%- comment -%}
  JSON-LD structured data for a single event page.
  Inputs:
    event: PageDrop
    speakers: array of team_member PageDrops (resolved by caller)
    status: 'upcoming' | 'live' | 'ended'
{%- endcomment -%}

{%- capture ev_title %}{% render 'page_title', item: event %}{% endcapture -%}
{%- assign ev_title = ev_title | strip -%}
{%- assign ev_desc = event.settings.description | strip_html | default: '' -%}
{%- assign ev_loc = event.settings.location | default: 'Online' -%}
{%- assign is_online = event.settings.is_online -%}
{%- assign cover = event.settings.cover_image | presence -%}
{%- assign video_url = event.settings.video_asset | default: event.settings.video_url | presence -%}

{%- assign jl_sd_raw = event.settings.start_datetime | presence -%}
{%- assign jl_ed_raw = event.settings.end_datetime | presence -%}
{%- assign jl_st = event.settings.start_time | presence -%}
{%- assign jl_et = event.settings.end_time | presence -%}
{%- assign jl_sd_str = '' -%}
{%- assign jl_ed_str = '' -%}
{%- if jl_sd_raw -%}{%- assign jl_sd_str = jl_sd_raw | date: '%Y-%m-%d' -%}{%- endif -%}
{%- if jl_ed_raw -%}{%- assign jl_ed_str = jl_ed_raw | date: '%Y-%m-%d' -%}{%- endif -%}

{%- assign start_iso = '' -%}
{%- if jl_sd_str != blank -%}
  {%- if jl_st -%}
    {%- assign start_iso = jl_sd_str | append: 'T' | append: jl_st -%}
  {%- else -%}
    {%- assign start_iso = jl_sd_str -%}
  {%- endif -%}
{%- endif -%}

{%- assign end_iso = '' -%}
{%- if jl_ed_str != blank -%}
  {%- if jl_et -%}
    {%- assign end_iso = jl_ed_str | append: 'T' | append: jl_et -%}
  {%- else -%}
    {%- assign end_iso = jl_ed_str -%}
  {%- endif -%}
{%- elsif jl_sd_str != blank and jl_et -%}
  {%- assign end_iso = jl_sd_str | append: 'T' | append: jl_et -%}
{%- endif -%}

{%- assign start_ts = start_iso | date: '%s' | plus: 0 -%}
{%- assign end_ts = end_iso | date: '%s' | plus: 0 -%}
{%- if end_ts == 0 and start_ts > 0 -%}
  {%- assign end_iso = start_ts | plus: 3600 | date: '%Y-%m-%dT%H:%M:%S' -%}
{%- endif -%}

{%- assign event_status_iri = 'https://schema.org/EventScheduled' -%}
{%- assign attendance_iri = 'https://schema.org/OnlineEventAttendanceMode' -%}
{%- if is_online == false and ev_loc != 'Online' -%}
  {%- assign attendance_iri = 'https://schema.org/OfflineEventAttendanceMode' -%}
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": {{ ev_title | to_json }},
  "description": {{ ev_desc | to_json }},
  "startDate": {{ start_iso | to_json }},
  "endDate": {{ end_iso | to_json }},
  "eventStatus": {{ event_status_iri | to_json }},
  "eventAttendanceMode": {{ attendance_iri | to_json }},
  {%- if cover %}
  "image": [{{ cover | to_json }}],
  {% endif -%}
  "url": {{ site.host | append: (event.path | default: event.url) | to_json }},
  "location": {
    {%- if attendance_iri == 'https://schema.org/OnlineEventAttendanceMode' %}
    "@type": "VirtualLocation",
    "url": {{ site.host | append: (event.path | default: event.url) | to_json }}
    {%- else %}
    "@type": "Place",
    "name": {{ ev_loc | to_json }},
    "address": {{ ev_loc | to_json }}
    {%- endif %}
  },
  "organizer": {
    "@type": "Organization",
    "name": {{ site.settings.brand_name | default: site.name | to_json }},
    "url": {{ site.host | to_json }}
  }
  {%- assign sp_size = speakers | size -%}
  {%- if sp_size > 0 %},
  "performer": [
    {%- for sp in speakers -%}
      {
        "@type": "Person",
        "name": {{ sp.link_text | default: sp.name | default: sp.title | to_json }}
        {%- assign sp_url = sp.settings.homepage_url | default: (site.host | append: (sp.path | default: sp.url)) -%}
        ,"url": {{ sp_url | to_json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
  {%- endif %}
}
</script>

{%- if status == 'ended' and video_url -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": {{ ev_title | to_json }},
    "description": {{ ev_desc | to_json }},
    "uploadDate": {{ end_iso | to_json }},
    {%- if cover %}
    "thumbnailUrl": [{{ cover | to_json }}],
    {% endif -%}
    "contentUrl": {{ video_url | to_json }},
    "embedUrl": {{ video_url | to_json }},
    "publisher": {
      "@type": "Organization",
      "name": {{ site.settings.brand_name | default: site.name | to_json }}
    }
  }
  </script>
{%- endif -%}
