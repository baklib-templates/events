{%- assign asset_url = item.settings.asset_url | presence -%}
{%- assign summary = item.settings.description | presence -%}

<div class="rounded-box border border-base-300/50 bg-base-100 p-5">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold leading-snug text-base-content">{% render 'page_title', item: item %}</h3>
    <i data-lucide="paperclip" class="h-4 w-4 shrink-0 text-base-content/50"></i>
  </div>
  {%- if summary -%}
    <p class="mt-2 text-sm text-base-content/70">{{ summary }}</p>
  {%- endif -%}
  <div class="mt-4 flex gap-2">
    <a
      href="{{ item.path | default: item.url }}"
      class="btn btn-outline btn-sm"
      data-turbo-frame="main-content-frame"
      data-turbo-action="advance"
    >Details</a>
    {%- if asset_url -%}
      <a href="{{ asset_url }}" class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer">Open</a>
    {%- endif -%}
  </div>
</div>
