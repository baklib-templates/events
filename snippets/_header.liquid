
{%- assign logo_url = site.settings.logo_url | presence -%}
{%- assign favicon_url = site.favicon_url | presence -%}
{%- assign brand_name = site.name -%}
{%- assign header_html = site.settings.header_html | presence -%}


<header class="sticky top-0 z-40 border-b border-base-300/50 bg-base-100/90 backdrop-blur" x-data="{ open: false }">
  <div class="page-container flex items-center justify-between gap-4 py-3">
    <a
      href="{{ site.index_path }}"
      class="flex min-w-0 items-center gap-3"
      aria-label="Home"
      data-turbo-frame="main-content-frame"
      data-turbo-action="advance"
    >
      {%- if logo_url -%}
        <img class="h-9 w-auto max-w-40 object-contain" src="{{ logo_url }}" alt="{{ brand_name | escape_once }}" loading="eager" />
      {%- elsif favicon_url -%}
        <img class="h-9 w-9 rounded-field object-cover" src="{{ favicon_url }}" alt="" loading="eager" />
        <span class="truncate text-base font-semibold text-base-content">{{ brand_name }}</span>
      {%- else -%}
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-field bg-primary text-sm font-bold text-primary-content">
          {{ brand_name | slice: 0 | upcase }}
        </span>
      {%- endif -%}
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-base-content/80 lg:flex" aria-label="Primary">
      {%- if header_html -%}
        {{ header_html }}
      {%- endif -%}
    </nav>

    <div class="hidden items-center gap-2 lg:flex">
      {%- if site.search_path -%}
        <a
          href="{{ site.search_path }}"
          class="btn btn-ghost px-3"
          aria-label="Search"
          data-turbo-frame="main-content-frame"
          data-turbo-action="advance"
        >
          <i data-lucide="search" class="h-4 w-4"></i>
          Search
        </a>
      {%- endif -%}
    </div>

    <button
      type="button"
      class="inline-flex h-9 w-9 items-center justify-center rounded-field text-base-content/70 hover:bg-base-content/5 hover:text-base-content lg:hidden"
      @click="open = !open"
      :aria-expanded="open"
      aria-label="Menu"
    >
      <i x-show="!open" data-lucide="menu" class="h-5 w-5"></i>
      <i x-show="open" x-cloak data-lucide="x" class="h-5 w-5"></i>
    </button>
  </div>

  <div class="border-t border-base-300/50 bg-base-100 lg:hidden" x-show="open" x-cloak style="display: none;">
    <nav class="space-y-1 px-4 py-3 text-sm" aria-label="Mobile">
      {%- if site.search_path -%}
        <a
          href="{{ site.search_path }}"
          class="block rounded-field px-3 py-2 hover:bg-base-200"
          data-turbo-frame="main-content-frame"
          data-turbo-action="advance"
          @click="open = false"
        >Search</a>
      {%- endif -%}
      {%- if header_html -%}
        <div class="pt-2 text-sm">{{ header_html }}</div>
      {%- endif -%}
    </nav>
  </div>
</header>
