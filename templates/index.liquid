<main class="flex-1 bg-base-100">
  {% query featured_q from site.pages %}
  {
    "where": {
      "template_name_eq": "channel",
      "settings.featured.value_eq": true
    },
    "order_by": ["published_at"],
    "limit": 1
  }
  {% endquery %}
  {%- assign featured = nil -%}
  {%- for item in featured_q limit: 1 -%}
    {%- assign featured = item -%}
  {%- endfor -%}
  {%- if featured == nil -%}
    {% query featured_fallback_q from site.pages %}
    {
      "where": {
        "template_name_eq": "channel"
      },
      "order_by": ["published_at"],
      "limit": 1
    }
    {% endquery %}
    {%- for item in featured_fallback_q limit: 1 -%}
      {%- assign featured = item -%}
    {%- endfor -%}
  {%- endif -%}
  <section class="border-b border-base-300/50 bg-gradient-to-br from-base-100 to-base-200/70">
    <div class="page-container py-14 lg:py-16">
      {%- if featured -%}
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Featured event</p>
            <h1 class="mt-3 text-4xl font-semibold tracking-tight text-accent lg:text-5xl">
              {% render 'page_title', item: featured %}
            </h1>
            {%- if featured.settings.intro != blank -%}
              <p class="mt-4 text-base text-base-content/75 lg:text-lg">{{ featured.settings.intro }}</p>
            {%- endif -%}
            <div class="mt-7">
              <a
                href="{{ featured.path | default: featured.url }}"
                class="btn btn-primary btn-lg"
                data-turbo-frame="main-content-frame"
                data-turbo-action="advance"
              >View details</a>
            </div>
          </div>
          <a
            href="{{ featured.path | default: featured.url }}"
            class="block overflow-hidden rounded-box border border-base-300/50 bg-base-200"
            data-turbo-frame="main-content-frame"
            data-turbo-action="advance"
          >
            {%- assign featured_hero = featured.settings.hero_image_url | default: featured.settings.thumb_image_url | presence -%}
            {%- if featured_hero -%}
              <img class="aspect-[16/10] w-full object-cover" src="{{ featured_hero }}" alt="" loading="lazy" />
            {%- else -%}
              <div class="flex aspect-[16/10] items-center justify-center text-base-content/30">
                <i data-lucide="calendar-days" class="h-14 w-14"></i>
              </div>
            {%- endif -%}
          </a>
        </div>
      {%- else -%}
        <h1 class="text-4xl font-semibold tracking-tight text-accent lg:text-5xl">{{ site.name }}</h1>
      {%- endif -%}
    </div>
  </section>

  {% query upcoming_q from page.children_in_list %}
  {
    "where": {
      "settings.start_datetime_gteq": "{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}"
    },
    "order_by": ["-published_at"],
    "limit": 12
  }
  {% endquery %}

  <section class="page-container py-12">
    <div class="mb-6 flex items-center justify-between gap-3">
      <h2 class="section-heading">Upcoming events</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {%- for ch in upcoming_q -%}
        {% render 'channel_card', channel: ch %}
      {%- endfor -%}
    </div>
    {%- assign upcoming_count = upcoming_q | size -%}
    {%- if upcoming_count == 0 -%}
      <p class="empty-state">No upcoming events yet.</p>
    {%- endif -%}
  </section>

  {% query recent_q from page.children_in_list %}
  {
    "where": {
      "template_name_eq": "channel",
      "settings.event_status.value_eq": "recent"
    },
    "order_by": ["-published_at"],
    "limit": 12
  }
  {% endquery %}
  <section class="page-container pb-12">
    <h2 class="section-heading">Recent events</h2>
    <div class="surface-panel mt-6">
      {%- for ch in recent_q -%}
        {%- assign start_raw = ch.settings.start_datetime | presence -%}
        <div class="list-row">
          <a href="{{ ch.path | default: ch.url }}" class="font-semibold text-base-content transition-colors hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: ch %}</a>
          <span class="text-sm text-base-content/60">{{ start_raw | date: "%b %d, %Y" }}</span>
        </div>
      {%- endfor -%}
      {%- assign recent_count = recent_q | size -%}
      {%- if recent_count == 0 -%}
        <p class="px-5 py-6 text-sm text-base-content/70">No recent events yet.</p>
      {%- endif -%}
    </div>
  </section>

  {% query past_q from page.children_in_list %}
  {
    "where": {
      "settings.event_status.value_eq": "past"
    },
    "order_by": ["-published_at"],
    "limit": 120
  }
  {% endquery %}
  <section class="page-container pb-12">
    <h2 class="section-heading">Past events</h2>
    <div class="surface-panel mt-6">
      {%- for ch in past_q -%}
        {%- assign end_raw = ch.settings.end_datetime | default: ch.settings.start_datetime | presence -%}
        <div class="list-row">
          <a href="{{ ch.path | default: ch.url }}" class="font-semibold text-base-content transition-colors hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: ch %}</a>
          <span class="text-sm text-base-content/60">{{ end_raw | date: "%b %d, %Y" }}</span>
        </div>
      {%- endfor -%}
      {%- assign past_count = past_q | size -%}
      {%- if past_count == 0 -%}
        <p class="px-5 py-6 text-sm text-base-content/70">No past events yet.</p>
      {%- endif -%}
    </div>
  </section>

  {% query speaker_q from site.pages %}
  {
    "where": {
      "template_style_eq": "person"
    },
    "order_by": ["published_at"],
    "limit": 12
  }
  {% endquery %}

  <section class="page-container pb-12">
    <h2 class="section-heading">Speakers</h2>
    <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {%- for person in speaker_q -%}
        {% render 'speaker_card', speaker: person %}
      {%- endfor -%}
    </div>
    {%- assign speaker_count = speaker_q | size -%}
    {%- if speaker_count == 0 -%}
      <p class="empty-state">No speakers published yet.</p>
    {%- endif -%}
  </section>

  {% query asset_q from site.pages %}
  {
    "where": {
      "template_style_eq": "asset"
    },
    "order_by": ["published_at"],
    "limit": 12
  }
  {% endquery %}
  <section class="page-container pb-14">
    <h2 class="section-heading">Assets</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {%- for item in asset_q -%}
        {% render 'asset_card', item: item %}
      {%- endfor -%}
    </div>
    {%- assign asset_count = asset_q | size -%}
    {%- if asset_count == 0 -%}
      <p class="empty-state">No assets published yet.</p>
    {%- endif -%}
  </section>
</main>

{% schema %}
  {
    "name": "Events Home",
    "description": "Homepage for featured events, event lists, speakers, and assets.",
    "thumb_url": "images/theme/preview-index.png",
    "preview_image_urls": ["images/theme/preview-index.png"],
    "sub_page_templates": ["channel"]
  }
{% endschema %}
