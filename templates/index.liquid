{%- comment -%}
  Index：直接 query 全部 events，按 published_at 倒序输出。时间分桶等待数据稳定后再加。
{%- endcomment -%}

{% query events_q from site.pages %}
{
  "where": {
    "template_name_eq": "event"
  },
  "order_by": ["-published_at"],
  "limit": 100
}
{% endquery %}

{%- assign hero_title_setting = site.settings.hero_title | presence -%}
{%- assign hero_description = site.settings.hero_description | presence -%}
{%- assign hero_url = site.settings.hero_url | strip -%}
{%- assign hero_cover_image = site.settings.hero_cover_image | presence -%}
{%- assign hero_cta_label = site.settings.cta_label | default: 'Learn more' -%}
{%- assign hero_display_title = hero_title_setting | default: site.settings.brand_name | default: site.name -%}

{%- assign press_logos = site.settings.press_logos_html | presence -%}

{%- if params.debug == '1' -%}
  {%- assign dbg_events_q_size = events_q | size -%}
  {%- assign sniff_events_first = events_q.first -%}
  <div class="border-b border-warning/40 bg-warning/10">
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <details open class="rounded-box border border-base-300 bg-base-100 p-4 text-base-content shadow-sm">
        <summary class="cursor-pointer select-none text-sm font-semibold text-warning-content marker:text-warning">
          Index template debug (<code class="text-xs">?debug=1</code>)
        </summary>
        <div class="mt-4 space-y-6 text-xs leading-relaxed">
          <dl class="grid gap-2 sm:grid-cols-[minmax(0,12rem)_1fr]">
            <dt class="font-semibold text-base-content/70">page (index)</dt>
            <dd>
              标量请用 <code>| to_json</code>。
              template_name={{ page.template_name | to_json }} · id={{ page.id | to_json }} · path={{ page.path | to_json }} · link_text={{ page.link_text | to_json }} · url={{ page.url | to_json }}
            </dd>
            <dt class="font-semibold text-base-content/70">All Events Section</dt>
            <dd>All Events Section count = {{ dbg_events_q_size }}</dd>
            <dt class="font-semibold text-base-content/70">events_q.first (to_json)</dt>
            <dd>
              <pre class="mt-1 max-h-48 overflow-auto rounded-md border border-base-300 bg-base-200/60 p-3 text-[11px] whitespace-pre-wrap">{%- if sniff_events_first -%}{{ sniff_events_first | to_json }}{%- else -%}(nil){%- endif -%}</pre>
            </dd>
            <dt class="font-semibold text-base-content/70">site.settings hero_*</dt>
            <dd>
              hero_title={{ hero_title_setting | to_json }} · hero_description={{ hero_description | to_json }} · hero_url={{ hero_url | to_json }} · hero_cover_image={{ hero_cover_image | to_json }}
            </dd>
            <dt class="font-semibold text-base-content/70">press_logos</dt>
            <dd>{%- if press_logos -%}set (non-empty HTML){%- else -%}(nil){%- endif -%}</dd>
            <dt class="font-semibold text-base-content/70">query 块（实际语法，便于截图）</dt>
            <dd>
              <p class="mb-2 text-[11px] text-base-content/60">首行仅允许 <code>query 变量名 from 集合</code>，条件为块内 JSON；无 <code>paginate</code> / <code>per_page</code> 等首行参数。</p>
              <pre class="max-h-64 overflow-auto rounded-md border border-base-300 bg-base-200/60 p-3 text-[11px] whitespace-pre-wrap">{% raw %}{% query events_q from site.pages %}
{
  "where": {
    "template_name_eq": "event"
  },
  "order_by": ["-published_at"],
  "limit": 100
}
{% endquery %}{% endraw %}</pre>
            </dd>
          </dl>
        </div>
      </details>
    </div>
  </div>
{%- endif -%}


{%- comment -%} ============ HERO（站点设置 site.settings，非自动活动） ============ {%- endcomment -%}
<section class="relative isolate overflow-hidden bg-secondary text-secondary-content">
  <div class="absolute inset-0 -z-10">
    {%- if hero_cover_image != blank -%}
      <img src="{{ hero_cover_image }}" alt="" class="h-full w-full object-cover opacity-30" />
    {%- endif -%}
    <div class="absolute inset-0 bg-gradient-to-r from-secondary via-secondary/85 to-secondary/40"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          {{ hero_display_title }}
        </h1>
        {%- if hero_description != blank -%}
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/80">{{ hero_description }}</p>
        {%- elsif site.settings.brand_slogan != blank -%}
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/80">{{ site.settings.brand_slogan }}</p>
        {%- endif -%}

        <div class="mt-10 flex flex-wrap items-center gap-3">
          {%- if hero_url != blank -%}
            <a
              href="{{ hero_url }}"
              class="btn btn-primary btn-lg"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >{{ hero_cta_label }}</a>
          {%- endif -%}
          {%- if site.settings.cta_url != blank -%}
            <a
              href="{{ site.settings.cta_url }}"
              class="btn btn-ghost-light btn-lg"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >{{ site.settings.cta_label | default: 'Browse all webinars' }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ============ Press Logos ============ {%- endcomment -%}
{%- if press_logos -%}
  <section class="border-b border-base-300/40 bg-base-100">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold uppercase tracking-wider text-base-content/60">Trusted by teams at</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 opacity-80">
        {{ press_logos }}
      </div>
    </div>
  </section>
{%- endif -%}

{%- comment -%} ============ All Events（全站 event 页，按 published_at 倒序） ============ {%- endcomment -%}
<section class="bg-base-100">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-primary">Events</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-base-content sm:text-4xl">All Events</h2>
      </div>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {%- for ev in events_q -%}
        {% render 'event_card', event: ev %}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%}
  ============ 以下区块已暂时停用（避免空白误导）；恢复分桶后可从 git 取回 ============
  Upcoming Events — 原依赖 upcoming_events
  Past replays — 原依赖 past_events
  Latest content — 原依赖 latest_posts + post_card
{%- endcomment -%}

{% schema %}
  {
    "name": "Index (B2B Webinar Hub)",
    "description": "Hero + all events list (time buckets deferred)",
    "thumb_url": "images/theme/preview-index.png",
    "preview_image_urls": ["images/theme/preview-index.png"],
    "sub_page_templates": ["event"]
  }
{% endschema %}
