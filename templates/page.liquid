{% set_meta_title page.name %}

{%- assign event_page = page.parent -%}
{%- assign cover = page.settings.thumb_image | presence -%}
{%- assign subtitle = page.settings.subtitle | presence -%}

<main class="flex-1 bg-base-100">
  <section class="border-b border-base-300/50 bg-base-100">
    <div class="page-container py-10">
      <nav class="mb-4 flex items-center gap-2 text-sm text-base-content/60">
        <a href="{{ site.index_path }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">Events</a>
        {%- if event_page -%}
          <span>/</span>
          <a href="{{ event_page.path | default: event_page.url }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: event_page %}</a>
        {%- endif -%}
        <span>/</span>
        <span class="text-base-content">{% render 'page_title', item: page %}</span>
      </nav>
      {%- if subtitle -%}
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-primary">{{ subtitle }}</p>
      {%- endif -%}
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-base-content lg:text-5xl">{% render 'page_title', item: page %}</h1>
      <p class="mt-4 text-sm text-base-content/60">
        {{ page.published_at | default: page.created_at | date: "%b %d, %Y" }}
      </p>
    </div>
  </section>

  <section class="page-container py-10 lg:py-12">
    {%- if cover -%}
      <div class="overflow-hidden rounded-box border border-base-300/50 bg-base-100">
        <img class="aspect-[16/9] w-full object-cover" src="{{ cover }}" alt="" loading="lazy" />
      </div>
    {%- endif -%}

    {%- if page.settings.description != blank -%}
      <p class="mx-auto mt-8 max-w-3xl text-lg leading-relaxed text-base-content/80">{{ page.settings.description }}</p>
    {%- endif -%}

    <article class="ProseMirror prose prose-neutral mx-auto mt-8 max-w-3xl">
      {{ page.settings.content }}
    </article>
  </section>
</main>

{% schema %}
  {
    "name": "Article Page",
    "description": "News report or event article detail page.",
    "thumb_url": "images/theme/preview-page.png",
    "preview_image_urls": ["images/theme/preview-page.png"],
    "sub_page_templates": [],
    "settings": [
      { "id": "subtitle", "type": "text", "label": "Subtitle" },
      {
        "id": "thumb_image",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 1200,
        "label": "Cover image"
      },
      { "id": "description", "type": "textarea", "label": "Summary", "rows": 3, "to_markdown": true },
      { "id": "content", "type": "richtext", "label": "Content", "to_markdown": true }
    ]
  }
{% endschema %}
