{%- comment -%}
  Page (news / report / article) detail under event → channel.
  Sidebar: other webinars (excluding current event) + sibling posts.
{%- endcomment -%}

{%- assign cover = page.settings.thumb_image | default: page.settings.thumb_image_url | presence -%}
{%- assign video = page.settings.video_asset | default: page.settings.video_url | presence -%}
{%- assign published = page.published_at | default: page.created_at -%}
{%- assign parent = page.parent -%}

{% query page_siblings_q from site.pages %}
{
  "where": {
    "template_name_eq": "page"
  },
  "order_by": ["-published_at"],
  "limit": 40
}
{% endquery %}
{%- assign siblings = '' | split: '' -%}
{%- if parent -%}
  {%- assign pr_id = parent.id -%}
  {%- for sib in page_siblings_q -%}
    {%- if sib.parent_id == pr_id -%}
      {%- assign siblings = siblings | concat: (sib | sort: 'created_at') -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign current_event = nil -%}
{%- if parent and parent.parent -%}
  {%- assign pp_tpl = parent.parent.template_name | default: '' -%}
  {%- if pp_tpl == 'event' -%}
    {%- assign current_event = parent.parent -%}
  {%- endif -%}
{%- endif -%}

{% query global_events_q from site.pages %}
{
  "where": {
    "template_name_eq": "event"
  },
  "order_by": ["-published_at"],
  "limit": 16
}
{% endquery %}
{%- assign recommended_events = '' | split: '' -%}
{%- for ev in global_events_q -%}
  {%- assign re_sz = recommended_events | size -%}
  {%- if re_sz < 4 -%}
    {%- if current_event == nil or ev.id != current_event.id -%}
      {%- assign recommended_events = recommended_events | concat: (ev | sort: 'created_at') -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{% capture _meta_pg_title %}{% render 'page_title', item: page %}{% endcapture %}
{% set_meta_title _meta_pg_title | strip %}
{% set_meta_description page.settings.description | strip_html | default: page.settings.subtitle %}

<main class="grow bg-base-100">
  <section class="border-b border-base-300/40 bg-base-200">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
      <nav class="flex flex-wrap items-center gap-2 text-sm text-base-content/60" aria-label="Breadcrumb">
        <a href="{{ site.index_path }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">Home</a>
        <span aria-hidden="true">/</span>
        {%- if parent and parent.parent -%}
          <a href="{{ parent.parent.path | default: parent.parent.url }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: parent.parent %}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        {%- if parent -%}
          <a href="{{ parent.path | default: parent.url }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: parent %}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        <span class="text-base-content">{% render 'page_title', item: page %}</span>
      </nav>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="grid gap-10 lg:grid-cols-3">
        <article class="lg:col-span-2">
          {%- if page.settings.subtitle != blank -%}
            <p class="text-xs font-semibold uppercase tracking-wider text-primary">{{ page.settings.subtitle }}</p>
          {%- elsif parent -%}
            <p class="text-xs font-semibold uppercase tracking-wider text-primary">{% render 'page_title', item: parent %}</p>
          {%- endif -%}
          <h1 class="mt-2 text-3xl font-bold leading-tight tracking-tight text-base-content sm:text-4xl">
            {% render 'page_title', item: page %}
          </h1>
          <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-base-content/60">
            <time datetime="{{ published | date: '%Y-%m-%d' }}">{{ published | date: '%b %d, %Y' }}</time>
            {%- assign tags_size = page.tags | size -%}
            {%- if tags_size > 0 -%}
              <span aria-hidden="true">·</span>
              <ul class="flex flex-wrap items-center gap-2">
                {%- for t in page.tags -%}
                  <li>
                    <a
                      href="{{ t.path | default: t.url }}"
                      class="inline-flex items-center rounded-full border border-base-300/50 px-2 py-0.5 text-xs font-medium text-base-content/80 hover:border-primary/50 hover:text-primary"
                      data-turbo-frame="main-content-frame"
                      data-turbo-action="advance"
                    >{{ t.name }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          {%- if video -%}
            <div class="mt-8 overflow-hidden rounded-2xl border border-base-300/40 bg-black">
              <video
                class="aspect-video w-full"
                src="{{ video }}"
                {% if cover %}poster="{{ cover }}"{% endif %}
                controls
                playsinline
                preload="metadata"
              ></video>
            </div>
          {%- elsif cover -%}
            <div class="mt-8 overflow-hidden rounded-2xl border border-base-300/40 bg-base-200">
              <img src="{{ cover }}" alt="" class="aspect-[16/9] w-full object-cover" />
            </div>
          {%- endif -%}

          {%- if page.settings.description != blank -%}
            <p class="mt-8 text-lg leading-relaxed text-base-content/80">{{ page.settings.description }}</p>
          {%- endif -%}

          <div class="prose mt-8 max-w-none">
            {{ page.settings.content }}
          </div>
        </article>

        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-8">
            {%- assign rec_size = recommended_events | size -%}
            {%- if rec_size > 0 -%}
              <div class="rounded-2xl border border-base-300/40 bg-base-100 p-5">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">Recommended webinars</h3>
                <ul class="mt-4 space-y-3">
                  {%- for ev in recommended_events limit: 4 -%}
                    <li>
                      <a
                        href="{{ ev.path | default: ev.url }}"
                        data-turbo-frame="main-content-frame"
                        data-turbo-action="advance"
                        class="group block"
                      >
                        <div class="line-clamp-2 text-sm font-semibold leading-snug text-base-content group-hover:text-primary">
                          {% render 'page_title', item: ev %}
                        </div>
                        {%- assign ev_start = ev.settings.start_datetime | presence -%}
                        {%- if ev_start -%}
                          <div class="mt-1 text-xs text-base-content/60">{{ ev_start | date: '%b %d, %Y' }}</div>
                        {%- endif -%}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}

            {%- assign sib_size = siblings | size -%}
            {%- if sib_size > 1 -%}
              <div class="rounded-2xl border border-base-300/40 bg-base-100 p-5">
                <h3 class="text-xs font-semibold uppercase tracking-wider text-base-content/60">More from {% render 'page_title', item: parent %}</h3>
                <ul class="mt-4 space-y-3">
                  {%- assign rendered = 0 -%}
                  {%- for sib in siblings -%}
                    {%- if sib.id != page.id and rendered < 4 -%}
                      {%- assign rendered = rendered | plus: 1 -%}
                      <li>{% render 'post_card', post: sib, variant: 'horizontal' %}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </div>
        </aside>
      </div>
    </div>
  </section>
</main>

{% schema %}
  {
    "name": "Article / news",
    "description": "Article detail with optional cover & video",
    "thumb_url": "images/theme/preview-page.png",
    "preview_image_urls": ["images/theme/preview-page.png"],
    "sub_page_templates": [],
    "settings": [
      { "id": "subtitle", "type": "text", "label": "Subtitle / category" },
      {
        "id": "thumb_image",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 800,
        "label": "Cover image"
      },
      {
        "id": "video_asset",
        "type": "video_picker",
        "label": "Video (DAM)",
        "ratio": "16:9",
        "width": 800,
        "info": "Optional. When set the article shows a video player above the body."
      },
      { "id": "video_url", "type": "text", "label": "Video URL (fallback)" },
      { "id": "description", "type": "textarea", "label": "Excerpt / short description", "to_markdown": true },
      { "id": "content", "type": "richtext", "label": "Body", "to_markdown": true }
    ]
  }
{% endschema %}
