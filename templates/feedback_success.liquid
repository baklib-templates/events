<main class="grow bg-base-100">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <div class="rounded-2xl border border-success/30 bg-base-100 p-10 text-center shadow-sm">
      <div class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-full bg-success/10 text-success">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="mt-6 text-2xl font-bold tracking-tight text-base-content">You're registered</h1>
      <p class="mt-3 text-base-content/70">{{ success | default: 'Thanks! We will email you the join link before the webinar.' }}</p>
      <div class="mt-8">
        <a class="btn btn-primary" href="{{ site.index_path }}" data-turbo-frame="main-content-frame" data-turbo-action="advance">Back to home</a>
      </div>
    </div>
  </div>
</main>
