{% layout none %}

<turbo-stream action="append" target="body">
  <template>
    <div
      class="fixed left-1/2 bottom-6 z-50 -translate-x-1/2"
      x-data
      x-init="setTimeout(() => { $el.remove() }, 5000)"
    >
      <div class="flex items-center gap-3 rounded-xl border border-error/40 bg-base-100 px-4 py-3 text-sm text-base-content shadow-lg">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-error/15 text-error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true"><path d="M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
        </span>
        <span class="font-semibold">{{ errors | default: 'Submission failed. Please try again.' }}</span>
      </div>
    </div>
  </template>
</turbo-stream>
