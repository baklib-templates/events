{% set_meta_title tag.name %}

<main class="grow bg-base-100">
  <section class="border-b border-base-300/40 bg-gradient-to-br from-base-100 to-base-200/70">
    <div class="page-container py-10 lg:py-14">
      <nav class="mb-3 flex items-center gap-2 text-sm text-base-content/60" aria-label="Breadcrumb">
        <a href="{{ site.index_path }}" class="breadcrumb-link" data-turbo-frame="main-content-frame" data-turbo-action="advance">Home</a>
        <span aria-hidden="true">/</span>
        <span>Tag</span>
        <span aria-hidden="true">/</span>
        <span class="text-base-content">{{ tag.name }}</span>
      </nav>
      <h1 class="text-3xl font-semibold tracking-tight text-accent sm:text-4xl">#{{ tag.name }}</h1>
    </div>
  </section>

  <section class="bg-base-100">
    <div class="page-container py-10 lg:py-14">
      {% paginate_tag tag.pages, as: 'items', per: 12 %}
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {% for it in items %}
            {%- assign it_tpl = it.template_name | default: '' -%}
            {%- if it_tpl == 'channel' -%}
              {% render 'channel_card', channel: it %}
            {%- elsif it_tpl == 'page.person' -%}
              {% render 'speaker_card', speaker: it %}
            {%- elsif it_tpl == 'page.asset' -%}
              {% render 'asset_card', item: it %}
            {%- else -%}
              {% render 'post_card', post: it %}
            {%- endif -%}
          {% else %}
            <p class="empty-state col-span-full p-10 text-center text-base-content/60">
              Nothing tagged yet.
            </p>
          {% endfor %}
        </div>

        {% if paginate.total_count > 0 %}
          <div class="mt-12 flex justify-center border-t border-base-300/40 pt-8">
            {% render 'paginate', paginate: paginate %}
          </div>
        {% endif %}
      {% endpaginate_tag %}
    </div>
  </section>
</main>
