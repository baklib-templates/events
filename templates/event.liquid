{%- comment -%}
  Single event detail page (templates/event.liquid).
  State machine: upcoming -> live -> ended.
  Speakers: team_member children under this page.
  Sub-channels: channel children with page previews.
  Emits Event + VideoObject JSON-LD, renders registration / live / replay UI.
{%- endcomment -%}

{%- assign now_ts = 'now' | date: '%s' | plus: 0 -%}

{%- comment -%} Compose ISO strings from `date` + `text` time fields. {%- endcomment -%}
{%- assign start_date_raw = page.settings.start_datetime | presence -%}
{%- assign end_date_raw = page.settings.end_datetime | presence -%}
{%- assign start_time_str = page.settings.start_time | presence -%}
{%- assign end_time_str = page.settings.end_time | presence -%}

{%- assign start_date_str = '' -%}
{%- assign end_date_str = '' -%}
{%- if start_date_raw -%}
  {%- assign start_date_str = start_date_raw | date: '%Y-%m-%d' -%}
{%- endif -%}
{%- if end_date_raw -%}
  {%- assign end_date_str = end_date_raw | date: '%Y-%m-%d' -%}
{%- endif -%}

{%- assign start_iso = '' -%}
{%- if start_date_str != blank -%}
  {%- if start_time_str -%}
    {%- assign start_iso = start_date_str | append: 'T' | append: start_time_str -%}
  {%- else -%}
    {%- assign start_iso = start_date_str -%}
  {%- endif -%}
{%- endif -%}

{%- assign end_iso = '' -%}
{%- if end_date_str != blank -%}
  {%- if end_time_str -%}
    {%- assign end_iso = end_date_str | append: 'T' | append: end_time_str -%}
  {%- else -%}
    {%- assign end_iso = end_date_str -%}
  {%- endif -%}
{%- elsif start_date_str != blank and end_time_str -%}
  {%- assign end_iso = start_date_str | append: 'T' | append: end_time_str -%}
{%- endif -%}

{%- assign start_ts = start_iso | date: '%s' | plus: 0 -%}
{%- assign end_ts = end_iso | date: '%s' | plus: 0 -%}
{%- if end_ts == 0 and start_ts > 0 -%}
  {%- assign end_ts = start_ts | plus: 3600 -%}
  {%- assign end_iso = end_ts | date: '%Y-%m-%dT%H:%M:%S' -%}
{%- endif -%}

{%- assign status = 'upcoming' -%}
{%- if start_ts == 0 -%}
  {%- assign status = 'tba' -%}
{%- elsif now_ts >= end_ts -%}
  {%- assign status = 'ended' -%}
{%- elsif now_ts >= start_ts -%}
  {%- assign status = 'live' -%}
{%- endif -%}

{% query speakers_q from site.pages %}
{
  "where": {
    "template_name_eq": "team_member"
  },
  "order_by": ["published_at"],
  "limit": 100
}
{% endquery %}
{%- assign speakers = '' | split: '' -%}
{%- for sp in speakers_q -%}
  {%- assign sp_par = sp.parent_id -%}
  {%- if sp_par == page.id -%}
    {%- assign speakers = speakers | concat: (sp | sort: 'created_at') -%}
  {%- endif -%}
{%- endfor -%}

{% query channels_q from site.pages %}
{
  "where": {
    "template_name_eq": "channel"
  },
  "order_by": ["published_at"],
  "limit": 100
}
{% endquery %}
{%- assign channel_pages = '' | split: '' -%}
{%- for ch in channels_q -%}
  {%- assign ch_par = ch.parent_id -%}
  {%- if ch_par == page.id -%}
    {%- assign channel_pages = channel_pages | concat: (ch | sort: 'created_at') -%}
  {%- endif -%}
{%- endfor -%}

{% query event_pages_q from site.pages %}
{
  "where": {
    "template_name_eq": "page"
  },
  "order_by": ["-published_at"],
  "limit": 120
}
{% endquery %}
{%- assign related_posts = '' | split: '' -%}
{%- for ch in channel_pages -%}
  {%- for p in event_pages_q -%}
    {%- assign p_par = p.parent_id -%}
    {%- if p_par == ch.id -%}
      {%- assign related_posts = related_posts | concat: (p | sort: 'created_at') -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}

{%- assign cover = page.settings.cover_image | presence -%}
{%- assign video_url = page.settings.video_asset | default: page.settings.video_url | presence -%}
{%- assign slides_url = page.settings.slides_url | presence -%}
{%- assign register_url = page.settings.register_url | presence -%}
{%- assign location = page.settings.location | presence | default: 'Online' -%}

{% capture _meta_evt_title %}{% render 'page_title', item: page %}{% endcapture %}
{% set_meta_title _meta_evt_title | strip %}
{% set_meta_description page.settings.description | strip_html | default: site.settings.brand_slogan %}

{% render 'jsonld_event', event: page, speakers: speakers, status: status %}

{%- if params.debug == '1' -%}
  <div class="border-b border-warning/40 bg-warning/10">
    <div class="mx-auto max-w-6xl px-4 py-4 sm:px-6 lg:px-8">
      <details open class="rounded-box border border-base-300 bg-base-100 p-4 text-base-content shadow-sm">
        <summary class="cursor-pointer select-none text-sm font-semibold text-warning-content marker:text-warning">
          Event template debug (<code class="text-xs">?debug=1</code>)
        </summary>
        <div class="mt-4 space-y-1 text-xs leading-relaxed">
          <dl class="grid gap-2 sm:grid-cols-[minmax(0,16rem)_1fr]">
            <dt class="font-semibold text-base-content/70">page</dt>
            <dd>template_name={{ page.template_name | to_json }} · path={{ page.path | to_json }}</dd>

            <dt class="font-semibold text-base-content/70">start_datetime raw</dt>
            <dd><code>{{ page.settings.start_datetime | json }}</code></dd>
            <dt class="font-semibold text-base-content/70">start_datetime | date: "%Y-%m-%d %H:%M"</dt>
            <dd><code>{{ page.settings.start_datetime | date: "%Y-%m-%d %H:%M" }}</code></dd>

            <dt class="font-semibold text-base-content/70">end_datetime raw</dt>
            <dd><code>{{ page.settings.end_datetime | json }}</code></dd>
            <dt class="font-semibold text-base-content/70">end_datetime | date: "%Y-%m-%d %H:%M"</dt>
            <dd><code>{{ page.settings.end_datetime | date: "%Y-%m-%d %H:%M" }}</code></dd>

            <dt class="font-semibold text-base-content/70">start_time</dt>
            <dd><code>{{ page.settings.start_time | json }}</code></dd>
            <dt class="font-semibold text-base-content/70">end_time</dt>
            <dd><code>{{ page.settings.end_time | json }}</code></dd>

            <dt class="font-semibold text-base-content/70">composed start_iso</dt>
            <dd><code>{{ start_iso | json }}</code></dd>
            <dt class="font-semibold text-base-content/70">composed end_iso</dt>
            <dd><code>{{ end_iso | json }}</code></dd>
            <dt class="font-semibold text-base-content/70">start_ts / end_ts / now_ts</dt>
            <dd><code>{{ start_ts }}</code> · <code>{{ end_ts }}</code> · <code>{{ now_ts }}</code></dd>
            <dt class="font-semibold text-base-content/70">status</dt>
            <dd><code>{{ status }}</code></dd>
          </dl>
        </div>
      </details>
    </div>
  </div>
{%- endif -%}

<main class="grow bg-base-100">
  {%- comment -%} ============ Hero ============ {%- endcomment -%}
  <section class="relative isolate overflow-hidden bg-secondary text-secondary-content">
    <div class="absolute inset-0 -z-10">
      {%- if cover -%}
        <img src="{{ cover }}" alt="" class="h-full w-full object-cover opacity-25" />
      {%- endif -%}
      <div class="absolute inset-0 bg-gradient-to-br from-secondary via-secondary/90 to-secondary/70"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      <nav class="mb-6 flex items-center gap-2 text-sm text-white/60" aria-label="Breadcrumb">
        <a href="{{ site.index_path }}" class="hover:text-white" data-turbo-frame="main-content-frame" data-turbo-action="advance">Home</a>
        <span aria-hidden="true">/</span>
        {%- if page.parent -%}
          <a href="{{ page.parent.path | default: page.parent.url }}" class="hover:text-white" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: page.parent %}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        <span class="text-white/80">{% render 'page_title', item: page %}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3">
        {% render 'event_status', event: page %}
        <span class="text-sm text-white/70">{{ location }}</span>
      </div>

      <h1 class="mt-4 max-w-4xl text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
        {% render 'page_title', item: page %}
      </h1>

      {%- if page.settings.description != blank -%}
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-white/80">{{ page.settings.description }}</p>
      {%- endif -%}

      <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-white/70">
        {%- if start_ts > 0 -%}
          <div class="flex items-center gap-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg>
            <time datetime="{{ start_iso }}">{{ start_date_raw | date: '%a, %b %d, %Y' }}</time>
          </div>
          {%- if start_time_str -%}
            <div class="flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-5 w-5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              <span>{{ start_time_str }}{% if end_time_str %} – {{ end_time_str }}{% endif %}</span>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ============ Status sections ============ {%- endcomment -%}

  {%- if status == 'live' -%}
    <section class="bg-base-200">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-2xl border border-error/40 bg-base-100 shadow-lg">
          <div class="flex items-center gap-2 border-b border-base-300/40 bg-error/10 px-5 py-3 text-sm font-semibold text-error">
            <span class="status-dot" aria-hidden="true"></span>
            Live now — broadcasting
          </div>
          <div class="aspect-video w-full bg-black">
            {%- if video_url -%}
              <video class="h-full w-full" src="{{ video_url }}" controls playsinline autoplay></video>
            {%- else -%}
              <div class="flex h-full w-full items-center justify-center text-white/70">
                <div class="text-center">
                  <div class="text-4xl font-bold">Live broadcast in progress</div>
                  <p class="mt-2 text-sm text-white/60">If the player does not load, please refresh the page.</p>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- elsif status == 'ended' -%}
    <section class="bg-base-200">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-2xl border border-base-300/50 bg-base-100 shadow-lg">
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-base-300/40 bg-base-200 px-5 py-3">
            <div class="flex items-center gap-2 text-sm font-semibold text-base-content">
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-primary" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
              On-demand replay
            </div>
            <div class="flex items-center gap-2">
              {%- if slides_url -%}
                <a
                  href="{{ slides_url }}"
                  target="_blank"
                  rel="noopener"
                  class="btn btn-primary"
                >
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4" aria-hidden="true"><path d="M12 3v12m0 0 4-4m-4 4-4-4"/><path d="M5 21h14"/></svg>
                  Download Slides
                </a>
              {%- endif -%}
            </div>
          </div>
          <div class="aspect-video w-full bg-black">
            {%- if video_url -%}
              <video
                class="h-full w-full"
                src="{{ video_url }}"
                {% if cover %}poster="{{ cover }}"{% endif %}
                controls
                playsinline
                preload="metadata"
              ></video>
            {%- else -%}
              <div class="flex h-full w-full items-center justify-center text-white/70 text-sm">Recording coming soon.</div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- assign spk_section_size = speakers | size -%}
  {%- if spk_section_size > 0 -%}
    <section id="speakers" class="scroll-mt-24 border-b border-base-300/40 bg-base-100">
      <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-primary">Speakers</p>
            <h2 class="mt-2 text-2xl font-bold tracking-tight text-base-content sm:text-3xl">Featured speakers</h2>
          </div>
        </div>
        <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
          {%- for sp in speakers -%}
            {% render 'speaker_card', speaker: sp %}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- assign ch_sections_size = channel_pages | size -%}
  {%- if ch_sections_size > 0 -%}
    {%- for ch in channel_pages -%}
      <section id="channel-{{ ch.slug }}" class="scroll-mt-24 border-b border-base-300/40 {% cycle 'bg-base-100', 'bg-base-200' %}">
        <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8 lg:py-16">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="max-w-3xl">
              <h2 class="text-2xl font-bold tracking-tight text-base-content sm:text-3xl">{% render 'page_title', item: ch %}</h2>
              {%- if ch.settings.description != blank -%}
                <p class="mt-3 text-base text-base-content/70">{{ ch.settings.description }}</p>
              {%- endif -%}
            </div>
            <a
              href="{{ ch.path | default: ch.url }}"
              class="btn btn-outline btn-sm shrink-0"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >View all</a>
          </div>
          {%- assign ch_posts = '' | split: '' -%}
          {%- for p in event_pages_q -%}
            {%- if p.parent_id == ch.id -%}
              {%- assign ch_posts = ch_posts | concat: (p | sort: 'created_at') -%}
            {%- endif -%}
          {%- endfor -%}
          {%- assign ch_posts = ch_posts | sort: 'published_at' | reverse -%}
          {%- assign ch_posts_preview_size = ch_posts | size -%}
          {%- if ch_posts_preview_size > 0 -%}
            <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {%- for post in ch_posts limit: 6 -%}
                {% render 'post_card', post: post %}
              {%- endfor -%}
            </div>
          {%- else -%}
            <p class="mt-8 rounded-lg border border-dashed border-base-300/60 bg-base-100/50 p-8 text-center text-sm text-base-content/60">
              No posts in this channel yet.
            </p>
          {%- endif -%}
        </div>
      </section>
    {%- endfor -%}
  {%- endif -%}

  {%- comment -%} ============ Body grid ============ {%- endcomment -%}
  <section class="bg-base-100">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <div class="grid gap-10 lg:grid-cols-3">
        <div class="lg:col-span-2">
          {%- if page.settings.content != blank -%}
            <article class="prose max-w-none">
              {{ page.settings.content }}
            </article>
          {%- endif -%}

          {%- if page.settings.agenda_html != blank -%}
            <section class="mt-12">
              <h2 class="border-b border-base-300/40 pb-3 text-2xl font-bold tracking-tight text-base-content">Agenda</h2>
              <div class="prose mt-6 max-w-none">{{ page.settings.agenda_html | raw }}</div>
            </section>
          {%- endif -%}

          {%- if status == 'ended' and page.settings.transcript_html != blank -%}
            <section class="mt-12" x-data="{ open: false }">
              <button
                type="button"
                class="flex w-full items-center justify-between rounded-xl border border-base-300/50 bg-base-100 px-5 py-4 text-left transition hover:border-primary/40 hover:bg-base-200"
                @click="open = !open"
                :aria-expanded="open"
              >
                <span class="text-base font-semibold text-base-content">Transcript</span>
                <svg class="h-5 w-5 transition" :class="open ? 'rotate-180' : ''" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div
                x-show="open"
                x-collapse
                x-cloak
                class="mt-2 rounded-xl border border-base-300/50 bg-base-100 p-6"
              >
                <div class="prose max-w-none">{{ page.settings.transcript_html | raw }}</div>
              </div>
            </section>
          {%- endif -%}

          {%- assign related_size = related_posts | size -%}
          {%- if related_size > 0 -%}
            <section class="mt-16">
              <h2 class="border-b border-base-300/40 pb-3 text-2xl font-bold tracking-tight text-base-content">Related coverage</h2>
              <div class="mt-6 grid gap-6 sm:grid-cols-2">
                {%- for post in related_posts -%}
                  {% render 'post_card', post: post %}
                {%- endfor -%}
              </div>
            </section>
          {%- endif -%}
        </div>

        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            {%- if status == 'upcoming' or status == 'tba' -%}
              {%- if register_url -%}
                <div class="rounded-2xl border border-base-300/50 bg-base-100 p-6 shadow-sm">
                  <h3 class="text-lg font-semibold tracking-tight text-base-content">Reserve your seat</h3>
                  <p class="mt-1 text-sm text-base-content/70">Registration is hosted by our partner.</p>
                  <a
                    href="{{ register_url }}"
                    target="_blank"
                    rel="noopener"
                    class="btn btn-primary btn-lg mt-5 w-full"
                  >Register now</a>
                </div>
              {%- else -%}
                {% render 'register_form', event: page %}
              {%- endif -%}
            {%- elsif status == 'ended' -%}
              <div class="rounded-2xl border border-base-300/50 bg-base-100 p-6 shadow-sm">
                <h3 class="text-lg font-semibold tracking-tight text-base-content">Get the resources</h3>
                <p class="mt-1 text-sm text-base-content/70">Watch the replay above or grab the supporting materials.</p>
                <div class="mt-5 space-y-3">
                  {%- if slides_url -%}
                    <a href="{{ slides_url }}" target="_blank" rel="noopener" class="btn btn-primary w-full">Download slides</a>
                  {%- endif -%}
                  {%- if video_url -%}
                    <a href="{{ video_url }}" target="_blank" rel="noopener" class="btn btn-outline w-full">Open video in new tab</a>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

            {%- if start_ts > 0 and status != 'ended' -%}
              <div class="rounded-2xl border border-base-300/50 bg-base-100 p-6 shadow-sm">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Schedule</h3>
                <dl class="mt-4 space-y-3 text-sm">
                  <div class="flex items-center justify-between">
                    <dt class="text-base-content/60">When</dt>
                    <dd class="font-medium text-base-content">
                      {{ start_date_raw | date: '%b %d, %Y' }}{% if start_time_str %} · {{ start_time_str }}{% endif %}
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="text-base-content/60">Duration</dt>
                    <dd class="font-medium text-base-content">
                      {%- assign mins = end_ts | minus: start_ts | divided_by: 60 -%}
                      {{ mins }} min
                    </dd>
                  </div>
                  <div class="flex items-center justify-between">
                    <dt class="text-base-content/60">Where</dt>
                    <dd class="font-medium text-base-content">{{ location }}</dd>
                  </div>
                </dl>
                <div class="mt-5">
                  {% render 'add_to_calendar', event: page %}
                </div>
              </div>
            {%- endif -%}

            {%- assign sp_size = speakers | size -%}
            {%- if sp_size > 0 -%}
              <div class="rounded-2xl border border-base-300/50 bg-base-100 p-6 shadow-sm">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-base-content/60">Speakers</h3>
                <ul class="mt-4 space-y-4">
                  {%- for sp in speakers -%}
                    <li>
                      <a
                        href="{{ sp.path | default: sp.url }}"
                        data-turbo-frame="main-content-frame"
                        data-turbo-action="advance"
                        class="group flex items-center gap-3 rounded-lg p-2 -m-2 hover:bg-base-200"
                      >
                        {% render 'speaker_avatar', speaker: sp, size: 'md' %}
                        <div class="min-w-0">
                          <div class="truncate text-sm font-semibold text-base-content group-hover:text-primary">
                            {% render 'page_title', item: sp %}
                          </div>
                          {%- if sp.settings.job_title != blank -%}
                            <div class="truncate text-xs text-base-content/60">{{ sp.settings.job_title }}{% if sp.settings.company %} · {{ sp.settings.company }}{% endif %}</div>
                          {%- endif -%}
                        </div>
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endif -%}
          </div>
        </aside>
      </div>
    </div>
  </section>
</main>

{% schema %}
  {
    "name": "Event detail",
    "description": "Single webinar / event hub with state machine + JSON-LD",
    "thumb_url": "images/theme/preview-page.png",
    "preview_image_urls": ["images/theme/preview-page.png"],
    "sub_page_templates": ["team_member", "channel"],
    "settings": [
      {
        "id": "start_datetime",
        "type": "date",
        "label": "Start date",
        "info": "Date value (YYYY-MM-DD). Used by Liquid date filter for the schedule and state machine."
      },
      {
        "id": "start_time",
        "type": "text",
        "label": "Start time (HH:MM, 24h)",
        "info": "Optional. Combined with start date to drive the live/ended state. Leave blank for all-day events.",
        "placeholder": "14:00"
      },
      {
        "id": "end_datetime",
        "type": "date",
        "label": "End date",
        "info": "Optional. Date value (YYYY-MM-DD). Defaults to start date when blank."
      },
      {
        "id": "end_time",
        "type": "text",
        "label": "End time (HH:MM, 24h)",
