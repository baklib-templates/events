{% set_meta_title page.name %}

{% query child_pages_q from site.pages %}
{
  "order_by": ["-published_at"],
  "limit": 300
}
{% endquery %}

{%- assign page_title = page.name | default: page.link_text -%}
{%- assign hero_image = page.settings.hero_image_url | default: page.settings.thumb_image_url | presence -%}
{%- assign intro = page.settings.intro | presence -%}
{%- assign event_type = page.settings.event_type | presence -%}
{%- assign start_dt = page.settings.start_datetime | presence -%}
{%- assign end_dt = page.settings.end_datetime | presence -%}
{%- assign address = page.settings.address | presence -%}
{%- assign registration_url = page.settings.registration_url | presence -%}
{%- assign key_points = page.settings.key_points | presence -%}
{%- assign video_asset = page.settings.video_url | presence -%}
{%- assign asset_url = page.settings.asset_url | presence -%}

<main class="flex-1 bg-base-100">
  <section class="border-b border-base-300/50 bg-gradient-to-br from-base-100 to-base-200/70">
    <div class="page-container py-12 lg:py-16">
      <nav class="mb-5 flex items-center gap-2 text-sm text-base-content/60">
        <a href="{{ site.index_path }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">Events</a>
        <span>/</span>
        <span class="text-base-content">{% render 'page_title', item: page %}</span>
      </nav>

      <div class="grid items-start gap-8 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Event</p>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-base-content lg:text-5xl">{{ page_title }}</h1>
          {%- if intro -%}
            <p class="mt-4 text-base text-base-content/75 lg:text-lg">{{ intro }}</p>
          {%- endif -%}
          <div class="mt-7 flex flex-wrap gap-3">
            {%- if registration_url -%}
              <a href="{{ registration_url }}" class="btn btn-primary btn-lg">Register now</a>
            {%- endif -%}
            {%- if asset_url -%}
              <a href="{{ asset_url }}" class="btn btn-outline btn-lg">Download asset</a>
            {%- endif -%}
          </div>
        </div>

        <div class="overflow-hidden rounded-box border border-base-300/50 bg-base-200">
          {%- if hero_image -%}
            <img class="aspect-[16/10] w-full object-cover" src="{{ hero_image }}" alt="" loading="lazy" />
          {%- else -%}
            <div class="flex aspect-[16/10] items-center justify-center text-base-content/30">
              <i data-lucide="calendar-heart" class="h-14 w-14"></i>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <section class="page-container py-10">
    <div class="grid gap-6 rounded-box border border-base-300/50 bg-base-100 p-6 md:grid-cols-2 xl:grid-cols-4">
      <div>
        <p class="text-xs uppercase tracking-wider text-base-content/50">Start</p>
        <p class="mt-1 font-medium text-base-content">{% if start_dt %}{{ start_dt | date: "%b %d, %Y" }}{% else %}TBA{% endif %}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wider text-base-content/50">End</p>
        <p class="mt-1 font-medium text-base-content">{% if end_dt %}{{ end_dt | date: "%b %d, %Y" }}{% else %}TBA{% endif %}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wider text-base-content/50">Event type</p>
        <p class="mt-1 font-medium text-base-content">{{ event_type | default: "General" }}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-wider text-base-content/50">Address</p>
        <p class="mt-1 font-medium text-base-content">{{ address | default: "Online" }}</p>
      </div>
    </div>
  </section>

  {%- if key_points -%}
    <section class="page-container pb-10">
      <h2 class="text-2xl font-bold tracking-tight text-base-content">Key points</h2>
      <div class="prose prose-neutral mt-4 max-w-none rounded-box border border-base-300/50 bg-base-100 p-6 text-base-content/85">
        {{ key_points | newline_to_br }}
      </div>
    </section>
  {%- endif -%}

  {%- if page.settings.content != blank -%}
    <section class="page-container pb-10">
      <h2 class="text-2xl font-bold tracking-tight text-base-content">Overview</h2>
      <article class="ProseMirror prose prose-neutral mt-4 max-w-none rounded-box border border-base-300/50 bg-base-100 p-6">
        {{ page.settings.content }}
      </article>
    </section>
  {%- endif -%}

  {%- if video_asset -%}
    <section class="page-container pb-10">
      <h2 class="text-2xl font-bold tracking-tight text-base-content">Video</h2>
      <div class="mt-4 overflow-hidden rounded-box border border-base-300/50 bg-base-100 p-2">
        <video class="aspect-video w-full rounded-lg object-cover" controls playsinline preload="metadata">
          <source src="{{ video_asset }}" />
        </video>
      </div>
    </section>
  {%- endif -%}

  <section class="page-container pb-14">
    <div class="grid gap-10 lg:grid-cols-3">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-base-content">News</h2>
        <div class="mt-5 space-y-4">
          {%- assign news_count = 0 -%}
          {%- for item in child_pages_q -%}
            {%- if item.parent_id == page.id and item.template_name == "page" -%}
              {%- assign news_count = news_count | plus: 1 -%}
              {% render 'post_card', post: item, variant: "horizontal" %}
            {%- endif -%}
          {%- endfor -%}
          {%- if news_count == 0 -%}
            <p class="rounded-box border border-dashed border-base-300/70 bg-base-200/40 p-4 text-sm text-base-content/70">No news content yet.</p>
          {%- endif -%}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold tracking-tight text-base-content">Speakers</h2>
        <div class="mt-5 grid gap-4">
          {%- assign person_count = 0 -%}
          {%- for item in child_pages_q -%}
            {%- if item.parent_id == page.id and item.template_name == "page.person" -%}
              {%- assign person_count = person_count | plus: 1 -%}
              {% render 'speaker_card', speaker: item %}
            {%- endif -%}
          {%- endfor -%}
          {%- if person_count == 0 -%}
            <p class="rounded-box border border-dashed border-base-300/70 bg-base-200/40 p-4 text-sm text-base-content/70">No speakers yet.</p>
          {%- endif -%}
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold tracking-tight text-base-content">Assets</h2>
        <div class="mt-5 space-y-4">
          {%- assign asset_count = 0 -%}
          {%- for item in child_pages_q -%}
            {%- if item.parent_id == page.id and item.template_name == "page.asset" -%}
              {%- assign asset_count = asset_count | plus: 1 -%}
              {% render 'asset_card', item: item %}
            {%- endif -%}
          {%- endfor -%}
          {%- if asset_count == 0 -%}
            <p class="rounded-box border border-dashed border-base-300/70 bg-base-200/40 p-4 text-sm text-base-content/70">No assets yet.</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>
</main>

{% schema %}
  {
    "name": "Event Channel",
    "description": "Landing page for one conference or webinar with event information, speakers, and assets.",
    "thumb_url": "images/theme/preview-index.png",
    "preview_image_urls": ["images/theme/preview-index.png"],
    "sub_page_templates": ["page", "page.person", "page.asset"],
    "settings": [
      {
        "id": "intro",
        "type": "textarea",
        "label": "Introduction",
        "rows": 3
      },
      {
        "id": "content",
        "type": "richtext",
        "label": "Content",
        "to_markdown": true
      },
      {
        "id": "key_points",
        "type": "textarea",
        "label": "Key points",
        "rows": 5,
        "to_markdown": true
      },
      {
        "id": "thumb_image_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 1200,
        "label": "Thumbnail image"
      },
      {
        "id": "hero_image_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 1600,
        "label": "Hero image"
      },
      {
        "id": "video_url",
        "type": "video_picker",
        "label": "Video",
        "ratio": "16:9",
        "width": 1200
      },
      {
        "id": "asset_url",
        "type": "dam_picker",
        "label": "Asset URL (DAM)"
      },
      {
        "id": "start_datetime",
        "type": "date",
        "label": "Start date"
      },
      {
        "id": "end_datetime",
        "type": "date",
        "label": "End date"
      },
      {
        "id": "event_type",
        "type": "select",
        "label": "Event type",
        "choices_from": "$site.event_type"
      },
      {
        "id": "address",
        "type": "text",
        "label": "Address"
      },
      {
        "id": "registration_url",
        "type": "text",
        "label": "Registration URL"
      },
      {
        "id": "featured",
        "type": "checkbox",
        "label": "Feature this event on homepage",
        "default": false
      }
    ]
  }
{% endschema %}
