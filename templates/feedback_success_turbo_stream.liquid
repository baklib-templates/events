{% layout none %}

<turbo-stream action="append" target="body">
  <template>
    <div
      class="fixed left-1/2 bottom-6 z-50 -translate-x-1/2"
      x-data
      x-init="setTimeout(() => { $el.remove() }, 4500)"
    >
      <div class="flex items-center gap-3 rounded-xl border border-success/40 bg-base-100 px-4 py-3 text-sm text-base-content shadow-lg">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-success/15 text-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
        </span>
        <span class="font-semibold">{{ success | default: 'Registered. Check your inbox.' }}</span>
      </div>
    </div>
  </template>
</turbo-stream>
