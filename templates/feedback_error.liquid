<main class="grow bg-base-100">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <div class="rounded-2xl border border-error/30 bg-base-100 p-10 text-center shadow-sm">
      <div class="mx-auto inline-flex h-12 w-12 items-center justify-center rounded-full bg-error/10 text-error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true"><path d="M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
      </div>
      <h1 class="mt-6 text-2xl font-bold tracking-tight text-base-content">Something went wrong</h1>
      <p class="mt-3 text-base-content/70">{{ errors | default: 'Please try again in a moment.' }}</p>
      <div class="mt-8">
        <a class="btn btn-outline" href="{{ site.index_path }}" data-turbo-frame="main-content-frame" data-turbo-action="advance">Back to home</a>
      </div>
    </div>
  </div>
</main>
