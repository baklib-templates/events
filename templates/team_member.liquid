{%- comment -%}
  Speaker / team member detail page (child of an event hub).
{%- endcomment -%}

{%- assign avatar = page.settings.avatar | presence -%}
{%- assign job_title = page.settings.job_title | presence -%}
{%- assign company = page.settings.company | presence -%}
{%- assign bio = page.settings.bio -%}
{%- assign homepage_url = page.settings.homepage_url | presence -%}
{%- assign linkedin_url = page.settings.linkedin_url | presence -%}
{%- assign twitter_url = page.settings.twitter_url | presence -%}

{%- assign event_page = page.parent -%}
{% query team_members_q from site.pages %}
{
  "where": {
    "template_name_eq": "team_member"
  },
  "order_by": ["published_at"],
  "limit": 80
}
{% endquery %}
{%- assign sibling_speakers = '' | split: '' -%}
{%- if event_page -%}
  {%- assign ev_pid = event_page.id -%}
  {%- for sib in team_members_q -%}
    {%- if sib.parent_id == ev_pid -%}
      {%- assign sibling_speakers = sibling_speakers | concat: (sib | sort: 'created_at') -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{% capture _meta_tm_title %}{% render 'page_title', item: page %}{% endcapture %}
{% set_meta_title _meta_tm_title | strip %}
{% set_meta_description page.settings.bio | strip_html | truncate: 160 %}

<main class="grow bg-base-100">
  <section class="border-b border-base-300/40 bg-base-200">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <nav class="mb-6 flex items-center gap-2 text-sm text-base-content/60" aria-label="Breadcrumb">
        <a href="{{ site.index_path }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">Home</a>
        <span aria-hidden="true">/</span>
        {%- if event_page -%}
          <a href="{{ event_page.path | default: event_page.url }}" class="hover:text-primary" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: event_page %}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        <span class="text-base-content">{% render 'page_title', item: page %}</span>
      </nav>

      {%- if event_page -%}
        <p class="mb-8 text-sm text-base-content/70">
          From:
          <a href="{{ event_page.path | default: event_page.url }}" class="font-semibold text-primary hover:underline" data-turbo-frame="main-content-frame" data-turbo-action="advance">{% render 'page_title', item: event_page %}</a>
        </p>
      {%- endif -%}

      <div class="grid gap-10 lg:grid-cols-3">
        <div class="lg:col-span-1">
          <div class="overflow-hidden rounded-2xl border border-base-300/40 bg-base-100">
            <div class="aspect-square w-full bg-base-200">
              {%- if avatar -%}
                {% capture _tm_alt %}{% render 'page_title', item: page %}{% endcapture %}
                <img src="{{ avatar }}" alt="{{ _tm_alt | strip | escape }}" class="h-full w-full object-cover" />
              {%- else -%}
                <div class="flex h-full w-full items-center justify-center text-5xl font-bold text-base-content/30">
                  {% capture _tm_init %}{% render 'page_title', item: page %}{% endcapture %}
                  {{ _tm_init | strip | slice: 0 | upcase }}
                </div>
              {%- endif -%}
            </div>
            <div class="space-y-3 p-5">
              {%- if homepage_url or linkedin_url or twitter_url -%}
                <div class="flex flex-wrap items-center gap-3">
                  {%- if homepage_url -%}
                    <a href="{{ homepage_url }}" target="_blank" rel="noopener" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-base-300/50 text-base-content/70 transition hover:border-primary/50 hover:text-primary" aria-label="Website">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
                    </a>
                  {%- endif -%}
                  {%- if linkedin_url -%}
                    <a href="{{ linkedin_url }}" target="_blank" rel="noopener" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-base-300/50 text-base-content/70 transition hover:border-primary/50 hover:text-primary" aria-label="LinkedIn">
                      <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M4 4h4v16H4zM6 2.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4zM10 8h4v2.2c.6-1.1 2-2.4 4.2-2.4 4.5 0 5.3 3 5.3 6.9V20h-4v-4.6c0-1.1 0-2.5-1.6-2.5-1.6 0-1.9 1.2-1.9 2.4V20h-4z"/></svg>
                    </a>
                  {%- endif -%}
                  {%- if twitter_url -%}
                    <a href="{{ twitter_url }}" target="_blank" rel="noopener" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-base-300/50 text-base-content/70 transition hover:border-primary/50 hover:text-primary" aria-label="X / Twitter">
                      <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M18.244 2H21l-6.51 7.44L22 22h-6.832l-4.83-6.31L4.6 22H2l7.05-8.06L1.5 2h6.99l4.4 5.81L18.245 2zm-2.4 18h1.873L8.27 4H6.293l9.55 16z"/></svg>
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Speaker</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-base-content sm:text-4xl">
            {% render 'page_title', item: page %}
          </h1>
          {%- if job_title or company -%}
            <p class="mt-2 text-base font-medium text-base-content/80">
              {{ job_title }}{% if job_title and company %} · {% endif %}{{ company }}
            </p>
          {%- endif -%}
          {%- if bio != blank -%}
            <article class="prose mt-6 max-w-none">{{ bio }}</article>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- assign sib_spk_size = sibling_speakers | size -%}
  {%- if event_page and sib_spk_size > 1 -%}
    <section class="border-t border-base-300/40 bg-base-100">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h2 class="text-lg font-semibold tracking-tight text-base-content">Speakers at this event</h2>
          <a
            href="{{ event_page.path | default: event_page.url }}#speakers"
            class="text-sm font-semibold text-primary hover:underline"
            data-turbo-frame="main-content-frame"
            data-turbo-action="advance"
          >View all speakers →</a>
        </div>
        <div class="mt-6 flex flex-wrap items-center gap-3">
          {%- for sib in sibling_speakers -%}
            <a
              href="{{ sib.path | default: sib.url }}"
              class="{% if sib.id == page.id %}ring-2 ring-primary ring-offset-2 ring-offset-base-100{% endif %} inline-block rounded-full"
              {% capture _sib_title %}{% render 'page_title', item: sib %}{% endcapture %}
              title="{{ _sib_title | strip | escape }}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
            >
              {% render 'speaker_avatar', speaker: sib, size: 'md' %}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
</main>

{% schema %}
  {
    "name": "Speaker (team_member)",
    "description": "Speaker profile under an event hub",
    "thumb_url": "images/theme/preview-page.png",
    "preview_image_urls": ["images/theme/preview-page.png"],
    "sub_page_templates": [],
    "settings": [
      { "id": "avatar", "type": "image_picker", "ratio": "1:1", "width": 320, "label": "Avatar" },
      { "id": "job_title", "type": "text", "label": "Job title", "queryable": true },
      { "id": "company", "type": "text", "label": "Company", "queryable": true },
      { "id": "homepage_url", "type": "text", "label": "Homepage URL" },
      { "id": "linkedin_url", "type": "text", "label": "LinkedIn URL" },
      { "id": "twitter_url", "type": "text", "label": "X / Twitter URL" },
      { "id": "bio", "type": "richtext", "label": "Bio", "to_markdown": true }
    ]
  }
{% endschema %}
